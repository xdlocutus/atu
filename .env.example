APP_NAME="Drafting Control Panel"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=sqlite
DB_DATABASE=database/app.sqlite

SESSION_NAME=draft_panel_session
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict

MAX_UPLOAD_MB=50
ALLOWED_EXTENSIONS=dwg,dxf,pdf,jpg,jpeg,png,webp,doc,docx,xlsx,zip
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MIN=15
