APP_NAME="Drafting Control Panel"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=draft_control
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_NAME=draft_panel_session
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Strict

MAX_UPLOAD_MB=50
ALLOWED_EXTENSIONS=dwg,dxf,pdf,jpg,jpeg,png,webp,doc,docx,xlsx,zip
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_MIN=15

COMPANY_NAME="Your Drafting Company"
COMPANY_EMAIL="info@example.com"
COMPANY_PHONE=""
COMPANY_ADDRESS=""
COMPANY_LOGO_URL=""
AUTOCAD_SHARED_ROOT=""
